<!DOCTYPE html>
<html>
  <head>
    <title><%= full_title(yield(:title)) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1"> <%#どのサイズの画面でも正しく表示させる新たなテンプレコード%>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %> <%#XSS攻撃を防ぐ 7.1.0以降のテンプレコード%>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %> <%#javascript記述用コード。2.7時点では不要だそうだが一応追記。%>
    <!-- HTML shimがこの1行で収まる -->
    <%= render 'layouts/shim' %>
  </head>
  <body>
    <!-- headerの内容がこの1行で収まる -->
    <%= render 'layouts/header' %>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>